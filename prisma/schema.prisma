generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  tasks         Task[]
  dailyEntries  DailyEntry[]
  manifestation Manifestation?
  dailyHealth   DailyHealth[]
  notifications Notification[]
  createdAt     DateTime        @default(now())
}

model DailyEntry {
  id        String   @id @default(cuid())
  userId    String
  mood      String
  gratitude String[]
  win       String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Manifestation {
  id           String   @id @default(cuid())
  userId       String   @unique
  affirmations String[]
  goalImageUrl String?
  scripting    String?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Task {
  id        String    @id @default(cuid())
  text      String
  completed Boolean   @default(false)
  category  String?
  dueDate   DateTime?
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime  @default(now())
}

model DailyHealth {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  waterGlasses  Int      @default(0)
  sleepHours    Float?
  movementLevel Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  title       String
  body        String
  type        String
  scheduledAt DateTime
  sent        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}